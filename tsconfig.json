{
  "include": ["./*.ts", "./cypress/**/*.ts"],
  "exclude": ["node_modules/**", "dist/**", "cypress.config.js"],
  "compilerOptions": {
    //"moduleResolution": "nodenext",
    "esModuleInterop": true,
    "strict": false,
    "module": "es2022",
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "target": "es2022",
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "types": ["cypress"]
  }
}
